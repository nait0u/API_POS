VITE_API_BASE=/api/<ruta_del_backend>/POS/AI_API
VITE_TOKEN_VERSION=<version>
VITE_DISPOSITIVO_ID=<id_del_dispositivo>
# Solo en desarrollo: override de EmpKey cuando el dispositivo tiene EmpKey=0.
# No incluir en producción.
VITE_DEV_EMP_KEY=

# Proxy targets para Vite dev server
VITE_PROXY_API_TARGET=http://<host_tomcat>:<puerto>
VITE_PROXY_BFF_TARGET=http://localhost:3000
